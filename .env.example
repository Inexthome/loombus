NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Server-only billing values
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
STRIPE_SECRET_KEY=your_stripe_secret_key

# Optional fallback configuration for general billing management.
STRIPE_BILLING_PORTAL_CONFIGURATION_ID=your_stripe_billing_portal_configuration_id

# Use separate product catalogs so membership and Room subscriptions cannot
# be switched into one another through Stripe.
STRIPE_BILLING_PORTAL_MEMBERSHIP_CONFIGURATION_ID=your_membership_portal_configuration_id
STRIPE_BILLING_PORTAL_ROOM_CONFIGURATION_ID=your_room_portal_configuration_id
